model Coupon {
    id                 String   @id @default(uuid())
    code               String   @unique
    description        String
    expiryDate         DateTime
    discountPercentage Float
    createdById        String?
    createdBy          User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt
}
