enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  photoUrl     String?
  role         Role     @default(USER)
  isSubscribed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}